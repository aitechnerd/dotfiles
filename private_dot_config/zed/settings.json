{
  "buffer_font_family": "JetBrains Mono",
  "project_panel": {
    "indent_size": 12.0,
    "dock": "right"
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Mocha",
    "dark": "One Dark"
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_diagnostics": "errors"
  },
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "soft_wrap": "editor_width",
  "relative_line_numbers": "enabled",
  "show_whitespaces": "selection",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "scrollbar": {
    "show": "never"
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false
  },

  // ── Disable built-in terminal ──
  "terminal": {
    "enabled": false
  },

  // ── Disable AI features (using Claude Code in Ghostty instead) ──
  "features": {
    "inline_completion_provider": "none"
  },
  "agent": {
    "enabled": false
  },

  // ── Reduce LSP memory pressure ──
  "inlay_hints": {
    "enabled": false
  },
  "diagnostics": {
    "inline": {
      "enabled": false
    }
  },

  // ── LSP config ──
  "lsp": {
    "nixd": {
      "binary": {
        "path_lookup": true
      }
    },
    "rust-analyzer": {
      "initialization_options": {
        "checkOnSave": false,
        "diagnostics": {
          "enable": false
        }
      }
    }
  },
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil"]
    }
  }
}
